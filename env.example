# weibo-crawler-next 配置示例
# 复制本文件为 .env (cp env.example .env) 后按需修改
# .env 文件已在 .gitignore 忽略, 不会入 commit

WCN_ENV=dev
WCN_HOST=127.0.0.1
WCN_PORT=28800

# 数据库 (默认 SQLite, 自动建库)
WCN_DATABASE_URL=sqlite+aiosqlite:///./data/wcn.db

# 微博 Cookie (可选 - 无 cookie 时仅能抓约 2000 条公开微博)
WCN_WEIBO_COOKIE=

# 抓取限频 (req/sec, 默认 1)
WCN_CRAWLER_RATE_LIMIT=1.0
WCN_CRAWLER_TIMEOUT=20
WCN_CRAWLER_RETRY_MAX=3
WCN_CRAWLER_PAGE_SIZE=10

# 调度器
WCN_SCHEDULER_ENABLED=true

# 日志
WCN_LOG_LEVEL=INFO
